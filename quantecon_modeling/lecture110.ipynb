     "name": "stdout",
     "output_type": "stream",
     "text": [
      "24\n"
     ]
    }
   ],
   "source": [
    "def p(x, coeffs):\n",
    "\n",
    "    powers = np.ones_like(coeffs)\n",
    "    powers[1:] = x\n",
    "    X_powers = np.cumprod(powers)\n",
    "    X_powers = X_powers * coeffs\n",
    "\n",
    "    return X_powers.sum()\n",
    "\n",
    "\n",
    "print(p(2,[2,3,4]))"
   ]
  }
 ],
